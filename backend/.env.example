# ============================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================
# Copy this to .env and fill in your own secret values.
# For Blue (production): generate ALL NEW keys — never share
# keys between staging and production.
#
# Generate keys with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Firebase Firestore project
FIREBASE_PROJECT_ID=smartroute-traffic

# Option A: Local JSON service account file path (recommended for local dev)
# Example: ./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# Option B: Inline credentials (recommended for cloud app settings)
FIREBASE_CLIENT_EMAIL=
# Keep literal \n sequences in this value (do NOT paste real line breaks)
FIREBASE_PRIVATE_KEY=

# CORS allowed origins (comma-separated, no spaces)
# Add your deployment URLs here (e.g. https://www.navocs.com)
ALLOWED_ORIGINS=http://localhost:5173

# Pepper for password hashing
PASSWORD_PEPPER=REPLACE_WITH_64_CHAR_HEX

# Previous pepper (for rotation — keep old pepper so existing users can login)
PASSWORD_PEPPER_PREVIOUS=

# AES-256 key for email encryption
EMAIL_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# HMAC key for email lookup
EMAIL_HMAC_KEY=REPLACE_WITH_64_CHAR_HEX

# JWT Secret
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# Frontend URL for redirects after email verification
FRONTEND_URL=http://localhost:5173

# Email verification settings
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TTL_MINUTES=1440
EMAIL_VERIFY_URL_BASE=http://localhost:3001

# Brevo transactional email settings
BREVO_API_KEY=
EMAIL_FROM=verify.user@navocs.com
EMAIL_FROM_NAME=SmartRoute
BREVO_TIMEOUT_MS=10000
BREVO_RETRY_ATTEMPTS=3
BREVO_RETRY_DELAY_MS=750

# OAuth sign-in (Google/GitHub)
# Local callback URLs shown below. For production, set to your backend URL:
#   https://traffic-backend-api.azurewebsites.net/api/auth/oauth/<provider>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/oauth/github/callback
OAUTH_STATE_TTL_MS=600000

# Rate limiting (milliseconds / max requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Make.com integration (optional, recommended for incident automation)
MAKE_ENABLED=false
MAKE_WEBHOOK_URL=
MAKE_TIMEOUT_MS=5000
MAKE_RETRY_ATTEMPTS=3
MAKE_RETRY_DELAY_MS=750

# Optional protection token for /api/ops/make-test
OPS_TEST_TOKEN=

# Retry strategy for outbound API calls
API_RETRY_ATTEMPTS=3
API_RETRY_BASE_DELAY_MS=600
API_TIMEOUT_MS=10000

# Notion integration (project management + activity log)
# 1. Go to https://www.notion.so/my-integrations → New Integration → copy token
# 2. Create a Notion database, share it with your integration
# 3. Copy the database ID from the URL (32-char string before the ?v= part)
NOTION_API_KEY=
NOTION_DATABASE_ID=
